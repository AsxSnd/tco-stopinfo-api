# nginx site for Vilnius lab:
#   https://stopinfo.vilnius.stjernberg.lab.suite.luminator.com
#
# TLS: wildcard cert for *.stjernberg.lab.suite.luminator.com
#
# Install:
#   sudo cp deploy/nginx-vilnius-stjernberg.conf.example \
#     /etc/nginx/sites-available/stopinfo-vilnius
#   sudo ln -s /etc/nginx/sites-available/stopinfo-vilnius /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Long server_name requires in /etc/nginx/nginx.conf inside http { }:
#   server_names_hash_bucket_size 128;
#   limit_req_zone $binary_remote_addr zone=stopinfo_vilnius:10m rate=50r/s;

upstream tco_stopinfo_vilnius {
    server 127.0.0.1:8084;
    keepalive 32;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name stopinfo.vilnius.stjernberg.lab.suite.luminator.com;

    # Long lab hostnames need a larger bucket (default 64 is too small)
    ssl_certificate     /home/stjernberg-linux/.acme.sh/stjernberg.lab.suite.luminator.com/fullchain.cer;
    ssl_certificate_key /home/stjernberg-linux/.acme.sh/stjernberg.lab.suite.luminator.com/stjernberg.lab.suite.luminator.com.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    # Optional rate limit (requires limit_req_zone in http { } — see header comment)
    # limit_req zone=stopinfo_vilnius burst=100 nodelay;

    access_log /var/log/nginx/stopinfo-vilnius.access.log;
    error_log  /var/log/nginx/stopinfo-vilnius.error.log;

    location /health {
        proxy_pass http://tco_stopinfo_vilnius;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/stopinfo/ {
        proxy_pass http://tco_stopinfo_vilnius;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        proxy_buffering off;
        proxy_read_timeout 10s;
        proxy_connect_timeout 3s;
    }

    location /debug/ {
        # Optional: restrict debug routes to lab networks only
        # allow 10.0.0.0/8;
        # allow 172.16.0.0/12;
        # deny all;

        proxy_pass http://tco_stopinfo_vilnius;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name stopinfo.vilnius.stjernberg.lab.suite.luminator.com;
    return 301 https://$host$request_uri;
}
